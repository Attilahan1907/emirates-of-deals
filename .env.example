# Flask Configuration
PORT=5000
FLASK_ENV=development

# Database Configuration
# Default is SQLite: sqlite:///./emirates_deals.db
# For PostgreSQL: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=sqlite:///./emirates_deals.db

# Redis Cache (Optional - Upstash free tier recommended)
# Get free Redis at https://upstash.com
# Format: redis://default:password@host:port
REDIS_URL=

# Notification Configuration (Optional)
TELEGRAM_BOT_TOKEN=dein_telegram_bot_token
# TELEGRAM_CHAT_ID (Wird normalerweise vom User im Frontend eingegeben)

# Web-Push (PWA) Configuration
# Generate keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=dein_public_key
VAPID_PRIVATE_KEY=dein_private_key

# eBay API (Optional, for better results)
EBAY_APP_ID=deine_ebay_app_id
EBAY_CERT_ID=deine_ebay_cert_id

# Scraper Scalability (Optional)
# List of proxies separated by comma
# Example: http://user:pass@proxy1.com:8080, http://proxy2.com:3128
PROXY_LIST=
